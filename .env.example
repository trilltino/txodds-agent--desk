# TxLINE
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_REALTIME=1
TXLINE_FIXTURE_ID=
# txoracle program watched by Yellowstone; defaults by TXLINE_NETWORK when empty
# (devnet 6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J, mainnet 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA)
TXLINE_PROGRAM_ID=

# Solana / escrow
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PAY_RECIPIENT=
SOLANA_PAY_SPL_TOKEN=
SOLANA_PAY_DEFAULT_AMOUNT_SOL=0.001
ESCROW_PROGRAM_ID=
ARBITER_PROGRAM_ID=
PAYER_KEYPAIR_PATH=~/.config/solana/id.json
ALLOW_MAINNET=0

# Triton One RPC Pool (tokens stay server-side; never exposed to the browser)
TRITON_DEVNET_RPC=https://your-endpoint.devnet.rpcpool.com
TRITON_DEVNET_TOKEN=
TRITON_MAINNET_RPC=https://your-endpoint.mainnet.rpcpool.com
TRITON_MAINNET_TOKEN=

# Triton One Yellowstone gRPC
TRITON_GRPC_ENDPOINT=
TRITON_X_TOKEN=
WATCH_ESCROW_PROGRAM_ID=
WATCH_MARKET_PROGRAM_ID=
WATCH_ESCROW_ACCOUNT=

# CoralOS sidecar / bridge
# CORALOS_ROOT points at a checkout of https://github.com/trilltino/solana_coralOS
# CORALOS_BRIDGE_URL can point at a custom bridge implementing docs/integrations/coralos-settlement.md
# CORALOS_TXODDS_PROXY is the existing txodds proxy in solana_coralOS examples/txodds/server/proxy.ts
CORALOS_SETTLEMENT_ENABLED=1
CORALOS_ROOT=
CORALOS_BRIDGE_URL=
CORALOS_TXODDS_PROXY=http://localhost:8801
CORALOS_AUTOSTART_PROXY=0
CORAL_SERVER_URL=http://localhost:5555
CORAL_TOKEN=dev
CORALOS_NAMESPACE=default
# `just dev` auto-starts a single coral-server container (docker-compose.coralos.yml)
# so the CoralOS Console is live on every machine. Only Docker itself is required;
# there are NO per-agent images to build. Override the server image if you mirror it.
CORAL_SERVER_IMAGE=ghcr.io/coral-protocol/coral-server:latest

# Set this to reuse an existing CoralOS session that already contains match-intelligence-agent.
CORALOS_SESSION_ID=
# When enabled, Rust publishes the real Match Intelligence transcript into Coral Console.
CORALOS_CONSOLE_ENABLED=1
CORALOS_SIDECAR_PATH=

# Agents / AI
#
# Two providers are supported (crates/rig-venice::active_provider() and
# native/src/services/llm/venice.rs both read this the same way):
#   - venice (default) — the original provider.
#   - groq — a genuinely free fallback for when Venice credits run out
#     (https://console.groq.com/keys, no card required). Left unset,
#     LLM_PROVIDER auto-detects from whichever *_API_KEY below is actually
#     set, preferring venice — so if your Venice key is still present but out
#     of quota, set LLM_PROVIDER=groq explicitly (or comment out
#     VENICE_API_KEY) rather than relying on auto-detection, since presence
#     of the key — not its remaining quota — is what auto-detection sees.
LLM_PROVIDER=venice
VENICE_API_KEY=
# Venice model for agent discussion; kimi-k2-7-code needs >=1024 max_tokens
LLM_MODEL=kimi-k2-7-code
# Prose model for the two narrative-quality call sites (fan-pundit-agent's
# verdict, sharp-movement-detector's signal rationale) — separate from the
# workspace's speed-tuned VENICE_MODEL/LLM_MODEL default on purpose, see
# rig_venice::DEFAULT_PROSE_MODEL. This value reaches
# `just run-agent-sharp-movement-detector` via just's dotenv-load; it does
# NOT reach fan-pundit-agent (a separate Docker container coral-server
# spawns) — that one gets its default straight from its own
# coral-agent.toml's VENICE_PROSE_MODEL option, so edit that file instead if
# you want to change its prose model.
VENICE_PROSE_MODEL=llama-3.3-70b

# Groq — free-tier fallback provider (see LLM_PROVIDER above). Get a key at
# https://console.groq.com/keys. GROQ_MODEL/GROQ_PROSE_MODEL follow the same
# speed-vs-prose split as their Venice equivalents above; leave unset to use
# rig_venice's defaults (llama-3.1-8b-instant / llama-3.3-70b-versatile —
# both free-tier, no card on file). fan-pundit-agent's Docker container gets
# GROQ_API_KEY/LLM_PROVIDER injected the same way it gets VENICE_API_KEY
# today (see native/src/services/coralos/console.rs::agent_graph_entry) —
# nothing else to configure for that agent specifically.
GROQ_API_KEY=
GROQ_MODEL=
GROQ_PROSE_MODEL=

# Set TRACE=1 to log LLM provider/model selection and raw replies
TRACE=0
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ODDS_MOVE_TRIGGER_PCT=5
MAX_DEVNET_SPEND_SOL=0.05

# Loopback diagnostics API (native/src/web.rs) — off by default. Enable only
# to give fan-pundit-agent (Docker-spawned) and/or a standalone
# sharp-movement-detector (`just run-agent-sharp-movement-detector`) read-only
# access to the ledger's leaderboard/signal/settlement/tool-call history via
# crates/rig-venice's Get* tools (AGENTIC-EXPANSION-PLAN.md, Priority 1).
DESK_AXUM_ENABLED=0
# Bind stays 127.0.0.1 (unreachable from Docker) unless you deliberately widen
# it. Only set to 0.0.0.0 if you want fan-pundit-agent's container to reach it
# via host.docker.internal — the bearer token below is still required either way.
DESK_AXUM_BIND=127.0.0.1
DESK_AXUM_PORT=47990
# Optional: pin the bearer token (instead of a fresh random one per launch) so
# a standalone `just run-agent-*` process started separately can authenticate
# with a value you copy into its own DESK_API_TOKEN env.
DESK_AXUM_TOKEN=
